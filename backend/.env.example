ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEWS_API_KEY=your_newsapi_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
WHALE_ALERT_API_KEY=your_whale_alert_api_key_here

# CoinGecko API key (optional but recommended for production)
# Without a key the free tier is used (≤10 req/min, shared IP pool).
# With a key the Pro API base URL is used (https://pro-api.coingecko.com/api/v3)
COINGECKO_API_KEY=

# Astro API integration (optional — platform degrades gracefully if not set)
ASTRO_API_URL=http://localhost:3001
ASTRO_API_KEY_INTERNAL=your_astro_api_key_here
ASTRO_SIGNAL_WEIGHT=0.1

# ── Site ───────────────────────────────────────────────────────────────────────
SITE_URL=https://starsignal.io
FRONTEND_URL=https://starsignal.io

# ── Auth — master flag ─────────────────────────────────────────────────────────
# AUTH_ENABLED=false → site behaves exactly as before (no login, no redirects)
# AUTH_ENABLED=true  → login required for protected routes, nav shows auth buttons
AUTH_ENABLED=false

# Secrets — generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace_with_64_char_random_hex
PARTNER_JWT_SECRET=replace_with_another_64_char_random_hex

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=choose_a_strong_password

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./waitlist.db

# ── Access mode (legacy) ───────────────────────────────────────────────────────
ACCESS_MODE=open

# ── Stripe (optional) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_FOUNDING_PRICE_ID=price_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# ── Affiliate / commissions ────────────────────────────────────────────────────
# STRIPE_CONNECT_CLIENT_ID — from Stripe Connect dashboard, enables automatic partner payouts
# Partner slugs and discount codes are auto-generated when a contact's status is set to "partner"
