VITE_API_URL=http://localhost:8000

# Auth master flag — must match AUTH_ENABLED in backend/.env
# false = no login UI, site works exactly as before
# true  = full auth system: login required for /dashboard /account /admin /partners/dashboard
VITE_AUTH_ENABLED=false

# Domain-based access control (no config needed — automatic)
# ai-trading-research.vercel.app → always open, auth never enforced, no login UI
#   Use this URL for internal testing and sharing with anyone, forever
# starsignal.io / www.starsignal.io → controlled by VITE_AUTH_ENABLED above
# Add any domain that should always be public to PUBLIC_DOMAINS in src/lib/auth.js
